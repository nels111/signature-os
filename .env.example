# Signature Cleans OS (SigOS) — Environment Variables
# Complete reference of EVERY env var the code reads (35 total).
# Verify completeness with:  grep -rhoE 'process\.env\.[A-Z_0-9]+' src | sed 's/process.env.//' | sort -u
# Copy to .env and fill real values. NEVER commit .env. Placeholders below are examples only.
# Required vars are validated at boot by src/lib/env.ts (fails fast with a clear message if missing).

# ─────────────────────────────────────────────────────────────
# Core / App  (REQUIRED)
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sigcleans?schema=public"  # Postgres connection (Prisma)
AUTH_SECRET="generate-with: openssl rand -base64 32"                              # NextAuth v5 JWT signing secret
NEXTAUTH_URL="https://os.signature-cleans.co.uk"                                  # Canonical app URL for NextAuth callbacks
APP_URL="https://os.signature-cleans.co.uk"                                       # App base URL (links in emails/notifications)
NODE_ENV="production"                                                             # production | development | test
NEXT_PUBLIC_APP_VERSION="1.0.0"                                                   # Shown in UI footer/settings
API_KEY="long-random-string"                                                      # Internal API key for protected/integration endpoints

# Client portal (the customer-facing portal SigOS links to)
CLIENT_PORTAL_URL="https://portal.signature-cleans.co.uk"                         # Server-side portal URL
NEXT_PUBLIC_PORTAL_URL="https://portal.signature-cleans.co.uk"                    # Client-side portal URL (exposed to browser)

# ─────────────────────────────────────────────────────────────
# OpenAI  (REQUIRED — website AI agent + audit summarisation)
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."                                                          # platform.openai.com → API keys

# ─────────────────────────────────────────────────────────────
# Twilio  (REQUIRED for cold-calling voice + WhatsApp) — 8 vars
# console.twilio.com
# ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="AC..."                                                        # Account SID
TWILIO_AUTH_TOKEN="..."                                                           # Auth token (webhook signature validation)
TWILIO_API_KEY_SID="SK..."                                                        # API Key SID (browser dialler tokens)
TWILIO_API_KEY_SECRET="..."                                                       # API Key secret
TWILIO_TWIML_APP_SID="AP..."                                                      # TwiML App SID (browser voice)
TWILIO_CALLER_NUMBER="+44..."                                                     # Outbound caller ID
TWILIO_WA_SENDER="whatsapp:+44..."                                                # WhatsApp sender (Twilio WA number)
TWILIO_SKIP_SIGNATURE_VALIDATION="false"                                          # DEV ONLY. Forced OFF in production by code — never bypass in prod.

# ─────────────────────────────────────────────────────────────
# Web Push / VAPID  (REQUIRED for push notifications)
# Generate with: npx web-push generate-vapid-keys
# ─────────────────────────────────────────────────────────────
VAPID_PRIVATE_KEY="..."                                                           # VAPID private key (server)
NEXT_PUBLIC_VAPID_PUBLIC_KEY="..."                                                # VAPID public key (browser)
VAPID_SUBJECT="mailto:hello@signature-cleans.co.uk"                               # VAPID subject (mailto or URL)

# ─────────────────────────────────────────────────────────────
# Email — IONOS IMAP/SMTP  (REQUIRED for email module + quote sends + notifications)
# ─────────────────────────────────────────────────────────────
SMTP_USER="user@signature-cleans.co.uk"                                           # SMTP/IMAP username
SMTP_PASS="..."                                                                   # SMTP/IMAP password
HELLO_MAILBOX_PASSWORD="..."                                                      # Password for the hello@ shared mailbox (cold-call/lead emails)
NOTIFICATION_EMAIL="nelson@signature-cleans.co.uk"                                # Where system notifications/alerts are sent
NOTIFICATION_EMAIL_FROM="SigOS <hello@signature-cleans.co.uk>"                    # From header for system emails

# ─────────────────────────────────────────────────────────────
# Connecteam  (REQUIRED — time clocks / shifts / operatives)
# ─────────────────────────────────────────────────────────────
CONNECTEAM_API_KEY="..."                                                          # Connecteam API key

# ─────────────────────────────────────────────────────────────
# Dropbox  (REQUIRED — Regular Hours Sheet + client folders)
# ─────────────────────────────────────────────────────────────
DROPBOX_APP_KEY="..."                                                             # Dropbox app key
DROPBOX_APP_SECRET="..."                                                          # Dropbox app secret
DROPBOX_REFRESH_TOKEN="..."                                                       # Long-lived refresh token (OAuth)
DROPBOX_HOURS_SHEET_PATH="/Regular Hours Sheet.xlsx"                              # Path to the hours sheet in Dropbox

# ─────────────────────────────────────────────────────────────
# Fireflies  (meeting transcripts)
# ─────────────────────────────────────────────────────────────
FIREFLIES_API_KEY="..."                                                          # app.fireflies.ai → API key

# ─────────────────────────────────────────────────────────────
# ElevenLabs  (voice/TTS)
# ─────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY="..."                                                          # elevenlabs.io → API key

# ─────────────────────────────────────────────────────────────
# Owner / notification identities  (REQUIRED — see src/lib/owner-config.ts)
# Moved out of source (no hardcoded UUIDs/personal numbers). Used by the website
# agent + lead intake to assign owners and send booking/enquiry alerts.
# ─────────────────────────────────────────────────────────────
AGENT_OWNER_USER_ID="<nelson-user-uuid>"                                          # Primary owner (Nelson) — owns website leads/events
AGENT_SECONDARY_USER_ID="<nick-user-uuid>"                                        # Secondary owner (Nick) — invited to events / notified
NELSON_WA_NUMBER="+44..."                                                         # Primary WhatsApp number for booking/enquiry alerts
NICK_WA_NUMBER="+44..."                                                           # Secondary WhatsApp number

# ─────────────────────────────────────────────────────────────
# Feature flags
# ─────────────────────────────────────────────────────────────
ENABLE_CADENCE="false"                                                            # Enable automated email cadence/nurture sends
NEXT_PUBLIC_ENABLE_ACCOUNTS="false"                                               # Show the CRM "Accounts" nav tab (archived per 9 Jun call; route/data kept)
