# Signature Cleans OS — Environment variables
# Copy to .env and fill with real values. NEVER commit the populated .env.

# --- Database ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/signature_cleans_os"
# Optional: Prisma 7 shadow DB (used by migrate diff / migrate dev).
# SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/signature_cleans_os_shadow"

# --- NextAuth v5 ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"
AUTH_TRUST_HOST=true
NEXTAUTH_URL="https://os.signature-cleans.co.uk"

# --- Runtime ---
PORT=3200
NODE_ENV=production

# --- Application origin (used by CSRF and absolute URL builders) ---
APP_URL="https://os.signature-cleans.co.uk"

# --- Feature flags ---
ENABLE_CADENCE=false

# --- API auth (Bearer token for server-to-server) ---
# Generate with: openssl rand -base64 32 | tr -d '=+/' | head -c 32
API_KEY="REPLACE_WITH_LONG_RANDOM_API_KEY"

# --- Email (IONOS shared mailbox) ---
HELLO_MAILBOX_PASSWORD="REPLACE_WITH_IONOS_PASSWORD"

# --- Dropbox / hours sheet ---
DROPBOX_HOURS_SHEET_PATH="/Signature Cleans (1)/Signature Cleans - Exeter & Newton Abbot/Financial Projections/Regular Hours Sheet 2025.xlsx"

# --- Optional integrations ---
# CONNECTEAM_API_KEY=
# FIREFLIES_API_KEY=
# OPENAI_API_KEY=
