generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============ ENUMS ============

enum Role {
  admin
  sales
  operations
  viewer
  va
}

enum LeadSource {
  cold_call
  cold_email
  referral
  website
  mark_walker  // legacy — use partner for new leads
  partner
  linkedin
  direct_mail
  other
}

enum LeadStage {
  new_lead
  contacted        // replaces cold_call/cold_email/linkedin as a stage
  meeting_scheduled
  meeting_attended
  quote_delivered
  negotiating
  won              // converted to client
  not_interested_for_now
  contact_when_contract_up
  foad
  // legacy / system stages kept for backward compat
  cold_call
  cold_email
  linkedin
  follow_up_sequence
  dormant
  bad_data
  archived
}

enum MeetingOutcome {
  good
  bad
  not_interested
}

enum DealStage {
  quote_sent
  follow_up_from_quote
  closed_won
  closed_lost
}

enum Priority {
  highest
  high
  normal
  low
  lowest
}

enum TaskStatus {
  not_started
  in_progress
  completed
  deferred
  waiting
}

enum TaskType {
  business
  personal
  mobilisation
  onboarding
  audit_action
  issue_followup
  callback
  follow_up_call
  contract_renewal_follow_up
  site_visit_confirmation
}

enum EventType {
  meeting
  site_survey
  follow_up
  calendly
  personal
}

enum CalendarType {
  personal
  shared
}

enum InviteStatus {
  pending
  accepted
  declined
}

enum QuoteStatus {
  draft
  sent
  viewed
  accepted
  rejected
  expired
  superseded
}

enum CadenceStatus {
  active
  paused_replied
  paused_meeting
  stopped_active_client
  completed
  long_term_nurture
}

enum CellTier {
  A
  B
  C
}

enum BillingType {
  hourly
  monthly_fixed
}

enum PortalStatus {
  not_invited  // site exists, no portal account yet
  invited      // magic link sent, not yet activated
  active       // client has logged in at least once
  suspended    // access revoked
}

enum TicketSeverity {
  low
  medium
  high
  critical
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum ServiceRequestStatus {
  pending    // submitted, awaiting admin review
  reviewing  // Nelson/Nick acknowledged
  approved   // scheduled
  completed
  declined
}

enum AuditStatus {
  draft      // form being filled
  published  // visible to client via portal
}

enum ComplianceStatus {
  valid           // doc present and not expiring within 30 days
  expiring_soon   // expires within 30 days
  expired         // past expiry date
  missing         // no doc on record
}

enum RtwType {
  uk_passport
  uk_birth_certificate
  share_code
  brp
  settled_status
  pre_settled_status
  other
}

enum NotificationType {
  task_due
  task_overdue
  event_reminder
  email_received
  deal_stage_changed
  lead_assigned
  invite_received
  cadence_reply
  audit_due
  shift_alert
  quote_sent
  quote_viewed
  task_assigned
  lead_cold_alert
  site_visit_booked
  client_ticket
  service_request
}

enum ActivityType {
  note
  call
  email
  email_sent
  meeting
  status_change
  task_completed
  lead_created
  deal_created
  quote_sent
  cadence_started
}

// ============ COLD CALLING ENUMS ============

enum ColdCallOutcome {
  no_answer
  voicemail_left
  gatekeeper
  callback_booked
  decision_maker_spoke
  site_visit_booked
  contract_renewal_date
  not_interested
  bad_data
}

enum QueueType {
  callback
  fresh
  follow_up
  recycle
  dormant
}

enum DecisionMakerSubOutcome {
  send_info
  follow_up_1_week
  follow_up_1_month
}

enum NotInterestedReason {
  happy_with_supplier
  in_house_team
  no_budget
  not_responsible
  never_outsource
  other
}

enum CallDirection {
  outbound
  inbound
}

enum CallStatus {
  queued
  ringing
  in_progress
  completed
  failed
  busy
  no_answer
  cancelled
}

// ============ MODELS ============

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(viewer)
  ionosEmail    String?
  ionosPassword String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts        Account[]
  contacts        Contact[]
  leads           Lead[]
  deals           Deal[]
  tasks           Task[]
  calendarEvents  CalendarEvent[]
  calendarInvites CalendarInvite[]
  emails          Email[]
  emailTemplates  EmailTemplate[]
  quotes          Quote[]
  notifications      Notification[]
  activities         Activity[]
  pushSubscriptions  PushSubscription[]
  timeSessions       TimeSession[]
  assignedTickets    ClientTicket[]
  audits             Audit[]
  coldCallAttempts   ColdCallAttempt[]

  @@map("users")
}

model Account {
  id        String    @id @default(cuid())
  name      String
  industry  String?
  website   String?
  phone     String?
  address   String?
  notes     String?
  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  creator  User      @relation(fields: [createdBy], references: [id])
  contacts Contact[]
  leads    Lead[]
  deals    Deal[]
  quotes   Quote[]

  @@index([createdBy])
  @@index([deletedAt])
  @@map("accounts")
}

model Contact {
  id        String      @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  company   String?
  accountId String?
  notes     String?
  source    LeadSource?
  createdBy String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  deletedAt DateTime?

  // Relations
  creator            User                @relation(fields: [createdBy], references: [id])
  account            Account?            @relation(fields: [accountId], references: [id])
  leads              Lead[]
  deals              Deal[]
  quotes             Quote[]
  emails             Email[]             @relation("ContactEmails")
  tasks              Task[]              @relation("ContactTasks")
  firefliesTranscripts FirefliesTranscript[] @relation("ContactTranscripts")

  @@index([createdBy])
  @@index([accountId])
  @@index([email])
  @@index([deletedAt])
  @@map("contacts")
}

model Lead {
  id             String          @id @default(cuid())
  companyName    String
  contactName    String?
  email          String?
  phone          String?
  source         LeadSource
  stage          LeadStage       @default(cold_call)
  meetingOutcome MeetingOutcome?
  ownerId        String
  notes          String?
  contactId      String?
  accountId      String?
  cadenceStatus  CadenceStatus?
  sector         String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stageChangedAt DateTime        @default(now())
  deletedAt      DateTime?

  // ── Cold calling queue control ──────────────────────────
  queueType          QueueType?
  nextCallAt         DateTime?
  lastCalledAt       DateTime?
  firstCalledAt      DateTime?
  coldCallAttempts   Int        @default(0)
  noAnswerAttempts   Int        @default(0)
  voicemailAttempts  Int        @default(0)
  gatekeeperAttempts Int        @default(0)
  isCallable         Boolean    @default(true)
  removedFromQueueAt DateTime?
  dormantUntil       DateTime?

  // ── Contact intelligence ────────────────────────────────
  decisionMakerName  String?
  decisionMakerTitle String?
  directNumber       String?
  bestTimeToCall     String?
  gatekeeperName     String?

  // ── Opportunity intelligence ────────────────────────────
  currentSupplier     String?
  contractRenewalDate DateTime?
  estimatedSiteSize   String?
  coldCallNotes       String?

  // ── Site visit ──────────────────────────────────────────
  siteVisitAt      DateTime?
  siteVisitAddress String?
  siteVisitContact String?

  // Relations
  owner    User     @relation(fields: [ownerId], references: [id])
  contact  Contact? @relation(fields: [contactId], references: [id])
  account  Account? @relation(fields: [accountId], references: [id])
  deals    Deal[]   @relation("LeadDeals")
  tasks    Task[]   @relation("LeadTasks")
  emails   Email[]  @relation("LeadEmails")
  cadences Cadence[]
  firefliesTranscripts FirefliesTranscript[] @relation("LeadTranscripts")
  callAttempts         ColdCallAttempt[]

  @@index([ownerId])
  @@index([contactId])
  @@index([accountId])
  @@index([stage])
  @@index([email])
  @@index([deletedAt])
  @@index([queueType, nextCallAt])
  @@index([isCallable, stage, nextCallAt])
  @@index([dormantUntil])
  @@index([lastCalledAt])
  @@map("leads")
}

model Deal {
  id              String    @id @default(cuid())
  name            String
  stage           DealStage @default(quote_sent)
  value           Decimal?  @db.Decimal(12, 2)
  weeklyHours     Decimal?  @db.Decimal(10, 4)
  ownerId         String
  contactId       String?
  accountId       String?
  quoteId         String?
  convertedFromId String?
  wonAt           DateTime?
  lostAt          DateTime?
  lossReason      String?
  notes           String?
  sector          String?
  closingDate     DateTime? @map("closing_date")
  probability     Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  stageChangedAt  DateTime  @default(now())
  deletedAt       DateTime?

  // Relations
  owner         User     @relation(fields: [ownerId], references: [id])
  contact       Contact? @relation(fields: [contactId], references: [id])
  account       Account? @relation(fields: [accountId], references: [id])
  convertedFrom Lead?    @relation("LeadDeals", fields: [convertedFromId], references: [id])
  tasks         Task[]   @relation("DealTasks")
  emails        Email[]  @relation("DealEmails")
  quotes        Quote[]
  firefliesTranscripts FirefliesTranscript[] @relation("DealTranscripts")

  @@index([ownerId])
  @@index([contactId])
  @@index([accountId])
  @@index([convertedFromId])
  @@index([stage])
  @@index([deletedAt])
  @@map("deals")
}

model Task {
  id              String     @id @default(cuid())
  subject         String
  ownerId         String
  dueDate         DateTime
  priority        Priority   @default(normal)
  status          TaskStatus @default(not_started)
  taskType        TaskType   @default(business)
  description     String?
  location        String?
  repeat          Json?
  reminder        Json?
  linkedLeadId    String?
  linkedDealId    String?
  linkedContactId String?
  previousStatus  TaskStatus?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  completedAt     DateTime?
  deletedAt       DateTime?

  // Relations
  owner         User     @relation(fields: [ownerId], references: [id])
  linkedLead    Lead?    @relation("LeadTasks", fields: [linkedLeadId], references: [id])
  linkedDeal    Deal?    @relation("DealTasks", fields: [linkedDealId], references: [id])
  linkedContact Contact? @relation("ContactTasks", fields: [linkedContactId], references: [id])

  @@index([ownerId])
  @@index([linkedLeadId])
  @@index([linkedDealId])
  @@index([linkedContactId])
  @@index([status, dueDate])
  @@index([deletedAt])
  @@map("tasks")
}

model CalendarEvent {
  id           String       @id @default(cuid())
  title        String
  eventType    EventType    @default(meeting)
  calendarType CalendarType @default(shared)
  allDay       Boolean      @default(false)
  startDate    DateTime
  endDate      DateTime
  notes        String?
  repeat       Json?
  alerts       Json?
  location     String?
  ownerId      String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  // Relations
  owner            User                      @relation(fields: [ownerId], references: [id])
  invites          CalendarInvite[]
  externalInvites  CalendarExternalInvite[]

  @@index([ownerId])
  @@index([startDate])
  @@index([deletedAt])
  @@map("calendar_events")
}

model CalendarInvite {
  id          String       @id @default(cuid())
  eventId     String
  inviteeId   String
  status      InviteStatus @default(pending)
  respondedAt DateTime?

  // Relations
  event   CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invitee User          @relation(fields: [inviteeId], references: [id])

  @@unique([eventId, inviteeId])
  @@index([inviteeId])
  @@map("calendar_invites")
}

model Email {
  id              String   @id @default(cuid())
  messageId       String
  mailbox         String
  from            String
  to              String[]
  cc              String[]
  subject         String
  bodyText        String?
  bodyHtml        String?
  date            DateTime
  isRead          Boolean  @default(false)
  folder          String   @default("INBOX")
  userId          String
  linkedLeadId    String?
  linkedDealId    String?
  linkedContactId String?
  trackingId      String?
  openCount       Int      @default(0)
  createdAt       DateTime @default(now())

  // Relations
  user          User              @relation(fields: [userId], references: [id])
  linkedLead    Lead?             @relation("LeadEmails", fields: [linkedLeadId], references: [id])
  linkedDeal    Deal?             @relation("DealEmails", fields: [linkedDealId], references: [id])
  linkedContact Contact?          @relation("ContactEmails", fields: [linkedContactId], references: [id])
  attachments   EmailAttachment[]

  @@unique([messageId, mailbox])
  @@index([userId])
  @@index([linkedLeadId])
  @@index([linkedDealId])
  @@index([linkedContactId])
  @@index([mailbox, folder, date])
  @@index([trackingId])
  @@map("emails")
}

model EmailAttachment {
  id          String   @id @default(cuid())
  emailId     String   @map("email_id")
  filename    String
  contentType String   @map("content_type")
  size        Int      @default(0)
  content     Bytes
  contentId   String?  @map("content_id")
  createdAt   DateTime @default(now()) @map("created_at")

  email Email @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@map("email_attachments")
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String
  subject     String
  bodyHtml    String
  mergeFields String[]
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  creator      User          @relation(fields: [createdBy], references: [id])
  cadenceSteps CadenceStep[]

  @@index([createdBy])
  @@map("email_templates")
}

model Quote {
  id            String      @id @default(cuid())
  dealId        String?
  accountId     String?
  contactId     String?
  status        QuoteStatus @default(draft)

  // Form data (stored for PDF generation and email preview)
  companyName   String?
  address       String?
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  siteType      String?
  hoursPerDay   Decimal?    @db.Decimal(10, 4)
  frequency     Int?
  days          String[]
  productCost   Decimal?    @default(0) @db.Decimal(12, 2)
  overheadCost  Decimal?    @default(0) @db.Decimal(12, 2)

  // Calculated pricing
  weeklyHours   Decimal     @db.Decimal(10, 4)
  sellRate      Decimal     @db.Decimal(12, 2)
  labourRate    Decimal     @default(17) @db.Decimal(10, 4)
  weeksPerMonth Decimal     @default(4.33) @db.Decimal(10, 4)
  isPilot       Boolean     @default(false)
  pilotDiscount Decimal?    @default(25) @db.Decimal(10, 4)
  monthlyTotal  Decimal     @db.Decimal(12, 2)
  annualTotal   Decimal     @db.Decimal(12, 2)
  margin        Decimal     @db.Decimal(10, 4)

  // PDF and email
  pdfPath       String?
  emailSubject  String?
  emailHtml     String?

  // Tracking
  sentAt        DateTime?
  viewedAt      DateTime?
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  trackingId    String?     @unique
  openCount     Int         @default(0)
  createdBy     String

  // Versioning: when a sent quote is edited, a clone is created and linked here
  supersededById String?
  supersededBy   Quote?  @relation("QuoteVersion", fields: [supersededById], references: [id])
  versions       Quote[] @relation("QuoteVersion")

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  creator User     @relation(fields: [createdBy], references: [id])
  deal    Deal?    @relation(fields: [dealId], references: [id])
  account Account? @relation(fields: [accountId], references: [id])
  contact Contact? @relation(fields: [contactId], references: [id])

  @@index([trackingId])
  @@index([createdBy])
  @@index([dealId])
  @@index([accountId])
  @@index([contactId])
  @@index([status])
  @@index([supersededById])
  @@map("quotes")
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
  message    String
  read       Boolean          @default(false)
  entityType String?
  entityId   String?
  createdAt  DateTime         @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@map("notifications")
}

model FirefliesTranscript {
  id              String   @id @default(cuid())
  firefliesId     String   @unique
  title           String
  date            DateTime
  summary         String?
  participants    String[]
  linkedLeadId    String?
  linkedDealId    String?
  linkedContactId String?
  createdAt       DateTime @default(now())

  // Relations
  linkedLead    Lead?    @relation("LeadTranscripts", fields: [linkedLeadId], references: [id])
  linkedDeal    Deal?    @relation("DealTranscripts", fields: [linkedDealId], references: [id])
  linkedContact Contact? @relation("ContactTranscripts", fields: [linkedContactId], references: [id])

  @@index([linkedLeadId])
  @@index([linkedDealId])
  @@index([linkedContactId])
  @@map("fireflies_transcripts")
}

model Activity {
  id           String       @id @default(cuid())
  activityType ActivityType
  description  String
  metadata     Json?
  userId       String
  entityType   String?
  entityId     String?
  createdAt    DateTime     @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@map("activities")
}

model ColdCallAttempt {
  id     String @id @default(cuid())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  direction CallDirection    @default(outbound)
  status    CallStatus       @default(queued)
  outcome   ColdCallOutcome?

  twilioCallSid      String? @unique
  twilioRecordingSid String?
  recordingUrl       String?

  startedAt       DateTime?
  answeredAt      DateTime?
  endedAt         DateTime?
  durationSeconds Int?

  notes String?

  // Snapshot fields captured from outcome form
  gatekeeperName          String?
  decisionMakerName       String?
  decisionMakerTitle      String?
  directNumber            String?
  email                   String?
  bestTimeToCall          String?
  contractRenewalDate     DateTime?
  currentSupplier         String?
  estimatedSiteSize       String?

  decisionMakerSubOutcome DecisionMakerSubOutcome?
  notInterestedReason     NotInterestedReason?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId, createdAt])
  @@index([userId, createdAt])
  @@index([outcome, createdAt])
  @@index([twilioCallSid])
  @@map("cold_call_attempts")
}

model Site {
  id                       String      @id @default(cuid())
  name                     String      // Display name e.g. "Porsche Centre Exeter"
  connecteamJobName        String?     // Exact title from Connecteam (for hours lookup)
  cellTier                 CellTier    @default(A)
  billingType              BillingType @default(hourly)
  billingRatePerHour       Decimal?    @db.Decimal(10, 2) // £/hr — used when billingType = hourly
  monthlyBillingValue      Decimal?    @db.Decimal(12, 2) // £/month — used when billingType = monthly_fixed
  labourRatePerHour        Decimal     @default(17) @db.Decimal(10, 4) // £/hr standard operative pay
  // Subcontractor fixed-cost override (e.g. Cleanz4U/Lisa invoices flat per contract).
  // When set, weekly cost = fixedMonthlyCost / 4.33 instead of hours × labourRatePerHour.
  fixedMonthlyCost         Decimal?    @db.Decimal(12, 2)
  rateConfirmed            Boolean     @default(false) // false = estimated, true = verified
  active                   Boolean     @default(true)
  notes                    String?
  regularHoursSheetRowId   String?     // Optional FK to canonical sheet row
  clientAccountId          String?     // FK to ClientAccount (one portal account per site)
  dropboxFolderPath        String?     // Maps the site to its Dropbox client folder (audit PDFs + portal docs)
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  // Relations
  regularHoursSheetRow RegularHoursSheetRow? @relation(fields: [regularHoursSheetRowId], references: [id])
  clientAccount        ClientAccount?        @relation(fields: [clientAccountId], references: [id])
  tickets              ClientTicket[]
  serviceRequests      ServiceRequest[]
  audits               Audit[]

  @@index([active])
  @@index([regularHoursSheetRowId])
  @@index([clientAccountId])
  @@map("sites")
}

// ============ REGULAR HOURS SHEET ============
// Canonical contracted-hours and revenue source.
// Synced from Dropbox: "Regular Hours Sheet 2025.xlsx" (Financial Projections folder).
// CT scheduler hours are PERMISSION WINDOWS, not work durations — these are the truth.
// Margin = avgWeeklyEarnings (revenue) − avgWeeklyHours × labour rate (cost).

enum HoursSheetRowStatus {
  active   // weeklyHours > 0, contract live
  pipeline // in sheet but no weekly hours yet (signed pending start)
}

model RegularHoursSheetRow {
  id                  String              @id @default(cuid())
  businessName        String              @unique // matches sheet "Business Name" column
  cleanType           String?             // sheet "Type Of Clean"
  hoursPerVisit       Decimal             @default(0) @db.Decimal(10, 4)
  frequencyPerWeek    Decimal             @default(0) @db.Decimal(10, 4)
  avgWeeklyHours      Decimal             @default(0) @db.Decimal(10, 4) // truth for cost basis + delivery target
  avgWeeklyEarnings   Decimal             @default(0) @db.Decimal(12, 2) // truth for revenue
  avgMonthlyEarnings  Decimal             @default(0) @db.Decimal(12, 2)
  signedTerms         Boolean             @default(false)
  annualValue         Decimal             @default(0) @db.Decimal(12, 2)
  firstAuditDate      DateTime?
  status              HoursSheetRowStatus @default(active)
  syncedAt            DateTime            @default(now())
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // Relations
  sites Site[]

  @@index([status])
  @@index([syncedAt])
  @@map("regular_hours_sheet_rows")
}

// ============ ORG SETTINGS (singleton) ============
// One row, id = "singleton". Holds editable org-wide defaults.
// Currently: default labour rate used for new sites + quote builder.
// Per-site labourRatePerHour overrides this when set.

model OrgSettings {
  id                       String   @id @default("singleton")
  defaultLabourRatePerHour Decimal  @default(17) @db.Decimal(10, 4)
  updatedBy                String?
  updatedAt                DateTime @updatedAt
  createdAt                DateTime @default(now())

  @@map("org_settings")
}

model Cadence {
  id          String        @id @default(cuid())
  leadId      String
  status      CadenceStatus @default(active)
  currentStep Int           @default(0)
  startedAt   DateTime      @default(now())
  pausedAt    DateTime?
  pauseReason String?
  nextSendAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  lead  Lead          @relation(fields: [leadId], references: [id])
  steps CadenceStep[]

  @@index([leadId])
  @@index([status, nextSendAt])
  @@map("cadences")
}

model CadenceStep {
  id         String    @id @default(cuid())
  cadenceId  String
  stepNumber Int
  templateId String
  delayDays  Int
  sentAt     DateTime?
  openedAt   DateTime?
  repliedAt  DateTime?

  // Relations
  cadence  Cadence       @relation(fields: [cadenceId], references: [id], onDelete: Cascade)
  template EmailTemplate @relation(fields: [templateId], references: [id])

  @@unique([cadenceId, stepNumber])
  @@index([templateId])
  @@map("cadence_steps")
}

// ============ UNDECLARED LIVE TABLES (added by schema-drift fix 2026-05-26) ============

/// External (non-user) invites to calendar events. Live table with no prior Prisma model.
model CalendarExternalInvite {
  id          String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  eventId     String
  email       String
  name        String?
  status      String    @default("pending")
  sentAt      DateTime?
  respondedAt DateTime?
  createdAt   DateTime  @default(now())

  // Relations
  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, email])
  @@index([email])
  @@index([eventId])
  @@map("calendar_external_invites")
}

/// Web-push subscriptions per user. Live table with no prior Prisma model.
model PushSubscription {
  id        String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String    @map("user_id")
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
  @@map("push_subscriptions")
}

/// Clock-in / clock-out sessions. Live table with no prior Prisma model.
/// user_id is VARCHAR(255) NOT NULL in the DB (not a cuid/uuid).
/// REVIEW NOTE: Task requested onDelete: SetNull but live column is NOT NULL.
/// To use SetNull the migration must first ALTER COLUMN user_id DROP NOT NULL.
/// Using Restrict here to match the live constraint safely; see data.md for options.
model TimeSession {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @map("user_id") @db.VarChar(255)
  clockedInAt     DateTime  @map("clocked_in_at") @db.Timestamptz(6)
  clockedOutAt    DateTime? @map("clocked_out_at") @db.Timestamptz(6)
  durationMinutes Int?      @map("duration_minutes")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations — Restrict to match NOT NULL constraint; change to SetNull only after making userId optional
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([clockedInAt])
  @@map("time_sessions")
}

// ============ CLIENT PORTAL ============
// ClientAccount  — one per site/contract. The portal login identity for a client.
// ClientTicket   — issues raised by client or admin (complaints, access problems, etc.)
// ServiceRequest — client-initiated upsell / add-on / service change request.
// Audit          — SigOS-native audit replacing the Connecteam form → Dropbox pipeline.

model ClientAccount {
  id                  String       @id @default(cuid())
  contactName         String       // Primary contact at the client
  contactEmail        String       @unique // Portal login email
  dropboxFolderPath   String?      // e.g. "/Signature Cleans (1)/.../Contract Cleaning Clients/Bott Ltd"
  hiddenFolders       Json         @default("[]") // Top-level Dropbox folder names hidden from this client's portal
  portalStatus        PortalStatus @default(not_invited)
  invitedAt           DateTime?
  lastLoginAt         DateTime?
  magicLinkToken      String?      @unique // bcrypt hash stored, never plain
  magicLinkExpiresAt  DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  // Relations — site has FK to this (Site.clientAccountId). Reverse to get the site:
  sites           Site[]
  tickets         ClientTicket[]
  serviceRequests ServiceRequest[]

  @@index([portalStatus])
  @@index([contactEmail])
  @@map("client_accounts")
}

model ClientTicket {
  id               String         @id @default(cuid())
  clientAccountId  String
  siteId           String?        // which site the issue relates to (optional — may span sites)
  title            String
  description      String
  severity         TicketSeverity @default(medium)
  photos           Json?          @default("[]") // array of Dropbox paths or base64 thumbnails
  status           TicketStatus   @default(open)
  assignedToId     String?        // User (Nelson/Nick) the ticket is assigned to
  resolvedAt       DateTime?
  resolutionNotes  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Relations
  clientAccount ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
  site          Site?         @relation(fields: [siteId], references: [id], onDelete: SetNull)
  assignedTo    User?         @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([clientAccountId])
  @@index([siteId])
  @@index([status, severity])
  @@index([assignedToId])
  @@map("client_tickets")
}

model ServiceRequest {
  id               String               @id @default(cuid())
  clientAccountId  String
  siteId           String?
  serviceType      String               // e.g. "Deep Clean", "Window Clean", "Ad Hoc Cover"
  description      String
  preferredDates   Json?               @default("[]") // array of ISO date strings client suggested
  status           ServiceRequestStatus @default(pending)
  adminNotes       String?              // internal notes from Nelson/Nick
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  // Relations
  clientAccount ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
  site          Site?         @relation(fields: [siteId], references: [id], onDelete: SetNull)

  @@index([clientAccountId])
  @@index([siteId])
  @@index([status])
  @@map("service_requests")
}

model Audit {
  id String @id @default(cuid())
  siteId     String
  auditedById String   // User who conducted the audit
  auditedAt  DateTime  @default(now())

  // Audit form type — mirrors the Connecteam Small/Large site audits
  formType    String  @default("large") // 'small' | 'large'
  siteVariant String?                    // large only: 'porsche_showroom' | 'crave'

  // Flexible per-site scoring (0-10 sliders). Categories vary by formType/variant.
  // [{ key, label, score (0-10), note? }]
  categories  Json  @default("[]")
  rawScore    Int   @default(0) // sum of category scores
  maxScore    Int   @default(0) // categories.length * 10
  overallScore Int  @default(0) // round(rawScore / maxScore * 100) — preserves 0-100 / 80-70 bands

  // Legacy 5-category columns (nullable; superseded by `categories`)
  scorePresentation   Int?
  scoreCleanliness    Int?
  scoreCompliance     Int?
  scoreEquipment      Int?
  scoreTeamConduct    Int?

  notePresentation  String?
  noteCleanliness   String?
  noteCompliance    String?
  noteEquipment     String?
  noteTeamConduct   String?

  binsEmptied    Boolean? // "Bins Emptied" yes/no
  issuesSpotted  String?  // "Issues Spotted"
  needsReview    String?  // "Needs review / actions by next audit"
  signatureData  String?  // Auditor signature (base64 PNG)

  headlineNotes     String?  // Executive summary for the client portal
  actionItems       Json?    @default("[]") // [{title, dueDate, assignedToId, completedAt}]
  photos            Json?    @default("[]") // base64 data URLs (interim) / Dropbox paths

  status            AuditStatus @default(draft)
  publishedAt       DateTime?   // When status flipped to published — visible in client portal
  dropboxPdfPath    String?     // Path after PDF is uploaded to Dropbox client folder

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  site       Site @relation(fields: [siteId], references: [id], onDelete: Restrict)
  auditedBy  User @relation(fields: [auditedById], references: [id], onDelete: Restrict)

  @@index([siteId, auditedAt])
  @@index([auditedById])
  @@index([status])
  @@index([overallScore])
  @@map("audits")
}

// ============ COMPLIANCE TRACKER ============

model Operative {
  id             String    @id @default(cuid())
  connecteamId   BigInt    @unique
  fullName       String
  entity         String    // Femi's Team | Kenkay Services | Signature Cleans | Cleans4U | JAR
  role           String?
  phone          String?
  startDate      DateTime?
  archived       Boolean   @default(false)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  compliance     Compliance?

  @@index([entity])
  @@index([archived])
  @@map("operatives")
}

model Compliance {
  id          String    @id @default(cuid())
  operativeId String    @unique
  operative   Operative @relation(fields: [operativeId], references: [id], onDelete: Cascade)

  // DBS
  dbsIssued            DateTime?
  dbsExpiry            DateTime?
  dbsCertificateNumber String?
  dbsUpdateService     Boolean   @default(false) // if true, no fixed expiry — check annually
  dbsStatus            ComplianceStatus @default(missing)

  // Insurance (Public Liability / Employer Liability)
  insuranceProvider     String?
  insuranceExpiry       DateTime?
  insurancePolicyNumber String?
  insuranceStatus       ComplianceStatus @default(missing)

  // Right to Work
  rtwType       RtwType?
  rtwExpiry     DateTime?  // null = permanent (UK passport / ILR / birth cert)
  rtwShareCode  String?
  rtwStatus     ComplianceStatus @default(missing)

  // Overall — worst of the three, recomputed by cron daily
  overallStatus ComplianceStatus @default(missing)

  lastReviewedAt  DateTime?
  lastReviewedBy  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dbsExpiry])
  @@index([insuranceExpiry])
  @@index([rtwExpiry])
  @@index([overallStatus])
  @@map("compliance_records")
}
